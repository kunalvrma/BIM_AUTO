# ============================================================
# BIM Automation Consulting — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ------------------------------------------------------------
# Resend Email API (https://resend.com)
# Required for the contact form to send emails.
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month
# ------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here

# The email address that receives contact form submissions
CONTACT_EMAIL=hello@bimautomation.consulting

# ------------------------------------------------------------
# Site URL (used for OG images and sitemap)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://bimautomation.consulting

# ------------------------------------------------------------
# Analytics (optional)
# Vercel Analytics is enabled automatically on Vercel.
# Uncomment if using a different provider.
# ------------------------------------------------------------
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
